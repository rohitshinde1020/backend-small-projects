# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net

# JWT
JWT_SECRET=<long-random-secret-at-least-32-chars>

# Redis
# Local:  redis://127.0.0.1:6379
# Remote: rediss://<username>:<password>@<host>:<port>
REDIS_URL=redis://127.0.0.1:6379

# Auth session TTL (seconds, default 86400 = 24 h)
SESSION_TTL_SECONDS=86400

# Brute-force / rate-limit settings
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_SECONDS=900

# Email (Brevo SMTP)
SENDER=no-reply@yourdomain.com
SMTP_USER=<brevo-smtp-login>
SMTP_PASSWORD=<brevo-smtp-key>

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost:5173
